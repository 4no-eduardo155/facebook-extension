{
  "manifest_version": 3,
  "name": "Arslan Marketplace Tools",
  "version": "3.0",
  "description": "Professional Marketplace Listing Manager",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "unlimitedStorage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.facebook.com/marketplace/you/selling*",
    "https://www.facebook.com/marketplace/create/item*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/marketplace/create/item*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
